<mvc:View
    controllerName="oms.orderscustom.controller.App"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:tnt="sap.tnt"
    displayBlock="true">
    <Shell>
        <tnt:ToolPage id="toolPage">
            <tnt:header>
                <tnt:ToolHeader>
                    <Button id="sideNavigationToggleButton"
                            icon="sap-icon://menu"
                            type="Transparent"
                            press=".onSideNavButtonPress" />
                    <Title text="Order Management System" />
                </tnt:ToolHeader>
            </tnt:header>

            <tnt:sideContent>
                <tnt:SideNavigation id="sideNavigation" itemSelect=".onSideNavItemSelect">
                    <tnt:NavigationList>
                        <tnt:NavigationListItem text="Orders" icon="sap-icon://sales-order" key="orders" />
                        <tnt:NavigationListItem text="Products" icon="sap-icon://product" key="products" />
                        <tnt:NavigationListItem text="Customers" icon="sap-icon://employee" key="customers" />
                    </tnt:NavigationList>
                </tnt:SideNavigation>
            </tnt:sideContent>

            <tnt:mainContents>
                <App id="app" busy="false"/>
            </tnt:mainContents>
        </tnt:ToolPage>
    </Shell>
</mvc:View>