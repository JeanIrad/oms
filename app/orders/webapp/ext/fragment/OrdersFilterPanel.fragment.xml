<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.ui.layout.form">
      <Panel headerText="Advanced order filter" expandable="true" expanded="true" class="sapUiSmallMarginBottom">
    <f:SimpleForm
      id="orderFilterForm"
      editable="true"
      layout="ColumnLayout"
      columnsM="2"
      columnsL="4"
      labelSpanM="12"
      labelSpanL="12">

      <Label text="From date"/>
      <DatePicker
        id="filterFromDate"
        valueFormat="yyyy-MM-dd"
        displayFormat="medium"
        placeholder="Select start date"/>

      <Label text="To date"/>
      <DatePicker
        id="filterToDate"
        valueFormat="yyyy-MM-dd"
        displayFormat="medium"
        placeholder="Select end date"/>

      <Label text="Customer"/>
      <Select
        id="filterCustomerSelect"
        items="{
          path: '/Customers',
          sorter: { path: 'name' }
        }">
        <core:Item key="" text="All customers"/>
        <core:Item key="{ID}" text="{name}"/>
      </Select>

      <Label text=" "/>
      <HBox>
        <Button
          text="Apply filter"
          type="Emphasized"
          press="oms.orders.ext.controller.OrdersListReportExt.onApplyOrderFilter"
          class="sapUiTinyMarginEnd"/>
        <Button
          text="Clear"
          press="oms.orders.ext.controller.OrdersListReportExt.onClearOrderFilter"/>
      </HBox>
    </f:SimpleForm>

    <Text id="filterResultText" class="sapUiSmallMarginTop" text=""/>
  </Panel>


</core:FragmentDefinition>