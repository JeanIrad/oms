{
  "name": "oms",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/audit-logging": "^1.2.2",
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "cloudinary": "^2.10.0",
    "dotenv": "^17.4.2",
    "multer": "^2.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1.0.1",
    "@cap-js/sqlite": "^2.4",
    "@faker-js/faker": "^10.4.0",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.17.0",
    "jest": "^30.4.2"
  },
  "scripts": {
    "start": "cds-serve",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:open": "jest --coverage && open coverage/lcov-report/index.html",
    "watch-orders": "cds watch --open oms.orders/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-customers": "cds watch --open oms.customers/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-products": "cds watch --open oms.products/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-ordersummary": "cds watch --open oms.ordersummary/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "collectCoverage": false,
    "collectCoverageFrom": [
      "srv/**/*.js",
      "!srv/**/node_modules/**",
      "!srv/**/*.test.js",
      "!srv/lib/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "text-summary",
      "html",
      "lcov"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "private": true,
  "cds": {
    "requires": {
      "db": {
        "[development]": {
          "kind": "sqlite",
          "credentials": {
            "url": "db.sqlite"
          }
        },
        "[production]": {
          "kind": "hana"
        }
      },
      "auth": {
        "[development]": {
          "kind": "mocked",
          "users": {
            "alice": {
              "password": "alice",
              "roles": [
                "authenticated-user"
              ]
            },
            "bob": {
              "password": "bob",
              "roles": [
                "authenticated-user"
              ]
            },
            "admin": {
              "password": "admin",
              "roles": [
                "authenticated-user",
                "admin"
              ]
            }
          }
        }
      },
      "[production]": {
        "auth": {
          "kind": "xsuaa"
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/orders",
    "app/customers",
    "app/products",
    "app/ordersummary",
    "app/orders",
    "app/products",
    "app/orders",
    "app/customers",
    "app/ordersummary"
  ]
}
