{
  "name": "oms",
  "version": "1.0.0",
  "dependencies": {
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1.0.1",
    "@cap-js/sqlite": "^2.4",
    "@faker-js/faker": "^10.4.0",
    "jest": "^30.4.2"
  },
  "scripts": {
    "start": "cds-serve",
    "test": "jest"
  },
  "private": true,
  "cds": {
    "requires": {
      "db": {
        "[development]": {
          "kind": "sqlite",
          "credentials": {
            "url": "db.sqlite"
          }
        },
        "[production]": {
          "kind": "hana"
        }
      },
      "auth": {
        "[development]": {
          "kind": "mocked",
          "users": {
            "alice": {
              "password": "alice",
              "roles": [
                "authenticated-user"
              ]
            },
            "bob": {
              "password": "bob",
              "roles": [
                "authenticated-user"
              ]
            },
            "admin": {
              "password": "admin",
              "roles": [
                "authenticated-user",
                "admin"
              ]
            }
          }
        }
      }
    }
  }
}
