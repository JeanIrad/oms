{
  "name": "oms",
  "version": "1.0.0",
  "dependencies": {
    "@sap/cds": "^9",
    "cloudinary": "^2.10.0",
    "dotenv": "^17.4.2",
    "multer": "^2.2.0"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1.0.1",
    "@cap-js/sqlite": "^2.4",
    "@faker-js/faker": "^10.4.0",
    "jest": "^30.4.2",
    "cds-plugin-ui5": "^0.17.0"
  },
  "scripts": {
    "start": "cds-serve",
    "test": "jest",
    "watch-orders": "cds watch --open oms.orders/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-customers": "cds watch --open oms.customers/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-products": "cds watch --open products/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "requires": {
      "db": {
        "[development]": {
          "kind": "sqlite",
          "credentials": {
            "url": "db.sqlite"
          }
        },
        "[production]": {
          "kind": "hana"
        }
      },
      "auth": {
        "[development]": {
          "kind": "mocked",
          "users": {
            "alice": {
              "password": "alice",
              "roles": [
                "authenticated-user"
              ]
            },
            "bob": {
              "password": "bob",
              "roles": [
                "authenticated-user"
              ]
            },
            "admin": {
              "password": "admin",
              "roles": [
                "authenticated-user",
                "admin"
              ]
            }
          }
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/orders",
    "app/customers",
    "app/products"
  ]
}
